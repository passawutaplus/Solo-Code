# Copy to .env and fill in values. NEVER commit .env to git.

# Canonical origin for OAuth callback (production). Dev uses window.location.origin.
# VITE_SITE_URL=https://www.solofreelancer.com

# --- Supabase (required) ---
# Project: rvnzjiskqliexysicfmh (supabase-blue-park)
VITE_SUPABASE_URL=https://rvnzjiskqliexysicfmh.supabase.co
VITE_SUPABASE_PUBLISHABLE_KEY=your_anon_key
SUPABASE_URL=https://rvnzjiskqliexysicfmh.supabase.co
SUPABASE_PUBLISHABLE_KEY=your_anon_key
# Server-only — never VITE_* or commit. Regenerate in Dashboard → API if leaked.
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key
# Dedicated secret for /api/public/cron/* (do not reuse service role in schedulers)
CRON_SECRET=generate_a_long_random_secret
VITE_SUPABASE_PROJECT_ID=rvnzjiskqliexysicfmh
# CLI only (never commit):
# SUPABASE_ACCESS_TOKEN=   → scripts/supabase-push-via-api.sh, supabase-setup-project.sh, supabase-backup-status.sh
# SUPABASE_DB_PASSWORD=    → scripts/supabase-push-pipeline.sh, supabase-backup.sh
# BACKUP_DIR=              → optional override (default ../backups/db from Solo-Code/)

# Cron (local VPS / WSL): daily pg_dump at 03:00
# ./scripts/install-backup-cron.sh
# GEMINI_API_KEY=          → Edge Functions + LINE AI (supabase secrets set)

# --- AI (Google Gemini — server + Supabase Edge Functions) ---
GEMINI_API_KEY=
# Optional model overrides (defaults: flash-lite / flash)
# GEMINI_MODEL_FAST=gemini-2.5-flash-lite
# GEMINI_MODEL=gemini-2.5-flash
# GEMINI_MODEL_VISION=gemini-2.5-flash

# --- Stripe / Payments ---
# pk_test_... or pk_live_... (client-safe publishable key)
# Test mode: use pk_test_ from Dashboard or after claiming sandbox (see scripts/stripe/SANDBOX_CLAIM.txt)
VITE_PAYMENTS_CLIENT_TOKEN=
# Force sandbox/live in local dev (overrides pk_* inference). Use sandbox for upgrade testing.
VITE_STRIPE_ENV=sandbox
# sk_test_... or rk_test_... — NOT the limited rkcs_test claimable key before sandbox is claimed
STRIPE_SANDBOX_API_KEY=
# sk_live_... for production catalog sync: npm run stripe:sync (with STRIPE_LIVE_API_KEY set)
STRIPE_LIVE_API_KEY=
# Webhook signing secrets from Stripe Dashboard → Developers → Webhooks
PAYMENTS_SANDBOX_WEBHOOK_SECRET=
PAYMENTS_LIVE_WEBHOOK_SECRET=
# Allowed origins for Stripe checkout redirect URLs (comma-separated, optional extra)
# PAYMENT_REDIRECT_ORIGINS_EXTRA=https://your-preview.vercel.app
# Supabase Edge Functions (supabase secrets set STRIPE_ENVIRONMENT=sandbox)
# STRIPE_ENVIRONMENT=sandbox

# --- Ecosystem (an1hem showcase) ---
# Local: http://localhost:8081/
VITE_ANTHEM_APP_URL=https://1px-demo.vercel.app/
# LINE Login channel (สร้างแยกจาก Messaging API) — OAuth/LIFF ใช้ ID ช่อง Login ไม่ใช่ 2010369565
VITE_LINE_CHANNEL_ID=
# Optional LIFF app id (create in LINE Console → LIFF → Endpoint URL = {origin}/line-link)
VITE_LINE_LIFF_ID=
# Supabase Edge Function secrets (never VITE_* or commit):
# LINE_CHANNEL_SECRET=              → LINE Login OAuth (supabase secrets set)
# LINE_CHANNEL_ACCESS_TOKEN=          → Messaging API push (line-queue-process)
# LINE_MESSAGING_CHANNEL_SECRET=      → Messaging API webhook verify (line-webhook)
# Ops Hub — ecosystem monitor (admin only)
VITE_OPS_HUB_URL=https://so1o-ops-hub.vercel.app

# VPS / Docker: use Stripe API directly (default when LOVABLE_API_KEY is unset)
STRIPE_USE_DIRECT=true
# Unified: same as SUPABASE_URL (ecosystem sync edge function optional when merged)
ANTHEM_SUPABASE_URL=https://rvnzjiskqliexysicfmh.supabase.co
# ECOSYSTEM_SYNC_SECRET=   # only if an1hem still on a separate project
# JOB_MATCH_DISPATCH_SECRET=  # Supabase edge fn job-match-dispatch (falls back to ECOSYSTEM_SYNC_SECRET)

# --- Launch mode ---
# Set to "true" to keep Early Access gate (tester_approved required)
# Omit or "false" for public signup
VITE_EARLY_ACCESS=false

# --- E2E (Playwright — local only, never commit real passwords) ---
# E2E_USER_EMAIL=test+usera@example.com
# E2E_USER_PASSWORD=
# E2E_USERB_EMAIL=test+userb@example.com
# E2E_USERB_PASSWORD=
# E2E_ADMIN_EMAIL=test+admin@example.com
# E2E_ADMIN_PASSWORD=
# E2E_UNVERIFIED_EMAIL=test+unverified@example.com
# E2E_UNVERIFIED_PASSWORD=
# E2E_BASE_URL=http://localhost:5173
# E2E_NO_SERVER=1   # skip webServer when E2E_BASE_URL points to remote

# --- UX Research demo (Vercel preview) ---
# Show researcher banner; keep false on production
VITE_DEMO_MODE=false

# --- Error monitoring (optional) ---
# Create project at https://sentry.io — leave empty to use console fallback only
# VITE_SENTRY_DSN=https://xxx@xxx.ingest.sentry.io/xxx
# Set to your Vercel preview URL after first deploy, e.g. https://solo-code-xxx.vercel.app
# Required for OAuth redirect whitelist in Supabase + canonical URLs
# VITE_SITE_URL=https://your-preview.vercel.app
