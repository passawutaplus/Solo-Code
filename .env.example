# Copy to .env and fill in values. NEVER commit .env to git.

# Canonical origin for OAuth callback (production). Dev uses window.location.origin.
# VITE_SITE_URL=https://www.solofreelancer.com

# --- Supabase (required) ---
# Project: rvnzjiskqliexysicfmh (supabase-blue-park)
VITE_SUPABASE_URL=https://rvnzjiskqliexysicfmh.supabase.co
VITE_SUPABASE_PUBLISHABLE_KEY=your_anon_key
SUPABASE_URL=https://rvnzjiskqliexysicfmh.supabase.co
SUPABASE_PUBLISHABLE_KEY=your_anon_key
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key
VITE_SUPABASE_PROJECT_ID=rvnzjiskqliexysicfmh
# CLI only (never commit):
# SUPABASE_ACCESS_TOKEN=   → scripts/supabase-push-via-api.sh, supabase-setup-project.sh
# SUPABASE_DB_PASSWORD=    → scripts/supabase-push-pipeline.sh (optional)
# GEMINI_API_KEY=          → scripts/supabase-setup-project.sh (Edge Functions)

# --- AI (Google Gemini — server + Supabase Edge Functions) ---
GEMINI_API_KEY=
# Optional model overrides (defaults: flash-lite / flash)
# GEMINI_MODEL_FAST=gemini-2.5-flash-lite
# GEMINI_MODEL=gemini-2.5-flash
# GEMINI_MODEL_VISION=gemini-2.5-flash

# --- Stripe / Payments ---
# pk_test_... or pk_live_... (client-safe publishable key)
VITE_PAYMENTS_CLIENT_TOKEN=
STRIPE_SANDBOX_API_KEY=
STRIPE_LIVE_API_KEY=

# --- Ecosystem (an1hem showcase) ---
VITE_ANTHEM_APP_URL=http://localhost:8081/

# VPS / Docker: use Stripe API directly (default when LOVABLE_API_KEY is unset)
STRIPE_USE_DIRECT=true
# Unified: same as SUPABASE_URL (ecosystem sync edge function optional when merged)
ANTHEM_SUPABASE_URL=https://rvnzjiskqliexysicfmh.supabase.co
# ECOSYSTEM_SYNC_SECRET=   # only if an1hem still on a separate project

# --- Launch mode ---
# Set to "true" to keep Early Access gate (tester_approved required)
# Omit or "false" for public signup
VITE_EARLY_ACCESS=false
