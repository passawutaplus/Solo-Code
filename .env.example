# Copy to .env and fill in values. NEVER commit .env to git.

# --- Supabase (required) ---
VITE_SUPABASE_URL=https://YOUR_PROJECT.supabase.co
VITE_SUPABASE_PUBLISHABLE_KEY=your_anon_key
SUPABASE_URL=https://YOUR_PROJECT.supabase.co
SUPABASE_PUBLISHABLE_KEY=your_anon_key
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key
VITE_SUPABASE_PROJECT_ID=your_project_id

# --- AI (Google Gemini — server + Supabase Edge Functions) ---
GEMINI_API_KEY=
# Optional model overrides (defaults: flash-lite / flash)
# GEMINI_MODEL_FAST=gemini-2.0-flash-lite
# GEMINI_MODEL=gemini-2.0-flash
# GEMINI_MODEL_VISION=gemini-2.0-flash

# --- Stripe / Payments ---
# pk_test_... or pk_live_... (client-safe publishable key)
VITE_PAYMENTS_CLIENT_TOKEN=
STRIPE_SANDBOX_API_KEY=
STRIPE_LIVE_API_KEY=

# --- Ecosystem (an1hem showcase) ---
VITE_ANTHEM_APP_URL=http://localhost:8081/

# VPS / Docker: use Stripe API directly (default when LOVABLE_API_KEY is unset)
STRIPE_USE_DIRECT=true
ANTHEM_SUPABASE_URL=https://uutbvwyoivqojozrangi.supabase.co
# Same value on an1hem edge function + So1o server (run: node scripts/ecosystem/setup.mjs)
ECOSYSTEM_SYNC_SECRET=
# Optional: mirror Pro without edge function
# ANTHEM_SUPABASE_SERVICE_ROLE_KEY=
# Target unified project ref when both apps share one DB
# VITE_UNIFIED_SUPABASE_PROJECT_ID=uutbvwyoivqojozrangi

# --- Launch mode ---
# Set to "true" to keep Early Access gate (tester_approved required)
# Omit or "false" for public signup
VITE_EARLY_ACCESS=false
